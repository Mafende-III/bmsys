// Beverage Business Management System
// Schema version 0.2 — matches docs/spec.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================================================================
// ENUMS
// ========================================================================

enum UserRole {
  OWNER
  SELLER
}

enum CartonState {
  OPENED
  EMPTY
}

enum PurchaseStatus {
  DRAFT
  RECEIVED
  CANCELLED
}

enum PaymentMethod {
  CASH
  MOMO
  BANK
  CREDIT
  MIXED
}

enum SaleStatus {
  COMPLETE
  PENDING
  CONFIRMED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum SaleSource {
  IN_PERSON
  ONLINE
  SUBSCRIPTION_AUTO
}

enum SaleUnit {
  UNIT
  CARTON
}

enum StockMoveReason {
  PURCHASE
  SALE_UNIT
  SALE_CARTON
  RETURN
  CARTON_OPEN
  ADJUSTMENT_BREAKAGE
  ADJUSTMENT_EXPIRY
  ADJUSTMENT_PERSONAL
  ADJUSTMENT_THEFT
  ADJUSTMENT_SAMPLE
  STOCKTAKE_VARIANCE
}

enum SubscriptionFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

enum LoyaltyReason {
  EARNED_PURCHASE
  EARNED_SUBSCRIPTION_TENURE
  REDEEMED
  BONUS
  EXPIRY
}

enum ReceiptFormat {
  PRINT
  SMS
  WHATSAPP
  EMAIL
}

enum ReceiptDeliveryStatus {
  QUEUED
  SENT
  FAILED
}

enum AuditAction {
  INSERT
  UPDATE
  DELETE
}

enum ExpensePaymentMethod {
  CASH
  MOMO
  BANK
}

enum RecurringFrequency {
  WEEKLY
  MONTHLY
}

// ========================================================================
// CORE
// ========================================================================

model User {
  id        String   @id @default(cuid())
  name      String
  phone     String   @unique
  pinHash   String
  role      UserRole @default(OWNER)
  active    Boolean  @default(true)
  language  String?  // "en" | "rw" — falls back to org default if null
  createdAt DateTime @default(now())

  stockMoves        StockMove[]
  cartonsOpened     Carton[]           @relation("OpenedBy")
  purchasesCreated  Purchase[]
  salesCreated      Sale[]
  creditMovements   CreditMovement[]
  cashSessionsOpened CashSession[]    @relation("Opened")
  cashSessionsClosed CashSession[]    @relation("Closed")
  adjustments       Adjustment[]
  expenses          Expense[]
  loyaltyMovements  LoyaltyMovement[]
  auditLogs         AuditLog[]
  channels          UserChannel[]
}

model Channel {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique
  active            Boolean  @default(true)
  requiresCustomer  Boolean  @default(false)
  createdAt         DateTime @default(now())

  priceOverrides ChannelPriceOverride[]
  customers      Customer[]
  sales          Sale[]
  users          UserChannel[]
}

/// Join table — which channels a user is allowed to sell on. OWNERs
/// bypass this check and are allowed on every channel. SELLERs need at
/// least one row to sell anything.
model UserChannel {
  userId    String
  channelId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@id([userId, channelId])
  @@index([channelId])
}

model Product {
  id                       String   @id @default(cuid())
  sku                      String   @unique
  name                     String
  categoryId               String?
  iconKey                  String?  // optional per-product Lucide icon (takes precedence over category)
  iconEmoji                String?  // optional per-product emoji (legacy fallback)
  /// Optional uploaded image. Takes precedence over iconKey and iconEmoji
  /// at the product level. Falls back to the category's image/icon when null.
  iconImagePath            String?
  unitsPerCarton           Int
  costPerCarton            Int      // RWF, integer (no decimals)
  unitPrice                Int      // RWF
  cartonPrice              Int      // RWF
  sellableAsUnit           Boolean  @default(true)
  sellableAsCarton         Boolean  @default(true)
  lowStockThresholdUnits   Int      @default(0)
  /// Minimum profit margin in basis points (10000 = 100%) that any sale
  /// of this product must keep after ad-hoc discounts. e.g. 3000 = "discount
  /// must leave at least 30% margin over cost". 0 means "fall back to the
  /// Settings.defaultMinMarginBps". Validated at checkout in createSaleOp.
  minMarginBps             Int      @default(0)
  loyaltyPointsPerUnit     Int      @default(0)
  active                   Boolean  @default(true)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  category              Category?              @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  channelPriceOverrides ChannelPriceOverride[]
  stockMoves            StockMove[]
  cartons               Carton[]
  purchaseLines         PurchaseLine[]
  saleLines             SaleLine[]
  adjustments           Adjustment[]
  subscriptions         Subscription[]
}

/// First-class product category. Holds the shared icon shown in the POS
/// grid. A product may override via `Product.iconEmoji`.
model Category {
  id            String   @id @default(cuid())
  name          String   @unique
  slug          String   @unique
  iconKey       String?
  iconEmoji     String   @default("📦")
  /// Optional uploaded image, relative path under the uploads volume
  /// (e.g. "category-icons/abc123.png"). Takes precedence over iconKey
  /// and iconEmoji when rendering on the POS.
  iconImagePath String?
  sortOrder     Int      @default(0)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())

  products Product[]
}

model ChannelPriceOverride {
  id          String  @id @default(cuid())
  productId   String
  channelId   String
  unitPrice   Int?
  cartonPrice Int?

  product Product @relation(fields: [productId], references: [id])
  channel Channel @relation(fields: [channelId], references: [id])

  @@unique([productId, channelId])
}

model Customer {
  id                  String   @id @default(cuid())
  name                String
  phone               String?
  primaryChannelId    String?
  deliveryGroup       String?
  deliveryRouteOrder  Int?
  notes               String?
  active              Boolean  @default(true)
  createdAt           DateTime @default(now())

  primaryChannel    Channel?           @relation(fields: [primaryChannelId], references: [id])
  sales             Sale[]
  creditMovements   CreditMovement[]
  loyaltyMovements  LoyaltyMovement[]
  subscriptions     Subscription[]
  customerUser      CustomerUser?
}

model Supplier {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  notes     String?
  createdAt DateTime @default(now())

  purchases Purchase[]
  expenses  Expense[]
}

// ========================================================================
// STOCK
// ========================================================================

model StockMove {
  id        String          @id @default(cuid())
  productId String
  qtyUnits  Int             // SIGNED delta
  reason    StockMoveReason
  refType   String?
  refId     String?
  note      String?
  userId    String
  createdAt DateTime        @default(now())

  product Product @relation(fields: [productId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([productId, createdAt])
  @@index([reason, createdAt])
}

model Carton {
  id                String      @id @default(cuid())
  productId         String
  tag               String      @unique
  state             CartonState
  unitsRemaining    Int
  openedAt          DateTime    @default(now())
  openedByUserId    String
  closedAt          DateTime?
  sourcePurchaseId  String?
  createdAt         DateTime    @default(now())

  product   Product    @relation(fields: [productId], references: [id])
  openedBy  User       @relation("OpenedBy", fields: [openedByUserId], references: [id])
  saleLines SaleLine[]

  @@index([productId, state])
}

// ========================================================================
// PURCHASES
// ========================================================================

model Purchase {
  id         String         @id @default(cuid())
  supplierId String
  date       DateTime
  status     PurchaseStatus @default(DRAFT)
  totalCost  Int            @default(0)
  note       String?
  userId     String
  createdAt  DateTime       @default(now())

  supplier Supplier       @relation(fields: [supplierId], references: [id])
  user     User           @relation(fields: [userId], references: [id])
  lines    PurchaseLine[]
}

model PurchaseLine {
  id              String  @id @default(cuid())
  purchaseId      String
  productId       String
  qtyCartons      Int     @default(0)
  qtyLooseUnits   Int     @default(0)
  unitCost        Int     // cost per carton, RWF
  lineTotal       Int

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])
}

// ========================================================================
// SALES
// ========================================================================

model Sale {
  id               String        @id @default(cuid())
  channelId        String
  customerId       String?
  date             DateTime      @default(now())
  total            Int           @default(0)
  paymentMethod    PaymentMethod
  paymentReference String?
  amountPaid       Int           @default(0)
  amountCredit     Int           @default(0)
  source           SaleSource    @default(IN_PERSON)
  status           SaleStatus    @default(COMPLETE)
  note             String?
  userId           String
  createdAt        DateTime      @default(now())

  channel  Channel    @relation(fields: [channelId], references: [id])
  customer Customer?  @relation(fields: [customerId], references: [id])
  user     User       @relation(fields: [userId], references: [id])
  lines    SaleLine[]
  receipts Receipt[]

  @@index([channelId, date])
  @@index([customerId, date])
  @@index([status])
}

model SaleLine {
  id        String   @id @default(cuid())
  saleId    String
  productId String
  saleUnit  SaleUnit
  qty       Int
  unitPrice Int
  /// Total RWF discount applied to this line (already factored into
  /// lineTotal). Always >= 0. Reason is required when > 0.
  discountAmount  Int     @default(0)
  discountReason  String?
  /// Was the per-product minMargin floor explicitly overridden by an
  /// owner at checkout? Audit-relevant; helps weekly reports flag
  /// margin-breaking discounts.
  floorOverride   Boolean @default(false)
  lineTotal Int
  cartonId  String?

  sale    Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product  @relation(fields: [productId], references: [id])
  carton  Carton?  @relation(fields: [cartonId], references: [id])
}

// ========================================================================
// CREDIT
// ========================================================================

model CreditMovement {
  id         String   @id @default(cuid())
  customerId String
  amount     Int      // SIGNED
  refType    String?
  refId      String?
  note       String?
  userId     String
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@index([customerId, createdAt])
}

// ========================================================================
// CASH
// ========================================================================

model CashSession {
  id            String    @id @default(cuid())
  openedAt      DateTime  @default(now())
  openedById    String
  openingFloat  Int
  closedAt      DateTime?
  closedById    String?
  closingCount  Int?
  expectedCash  Int?
  variance      Int?
  note          String?

  openedBy User  @relation("Opened", fields: [openedById], references: [id])
  closedBy User? @relation("Closed", fields: [closedById], references: [id])
}

// ========================================================================
// ADJUSTMENTS
// ========================================================================

model Adjustment {
  id        String          @id @default(cuid())
  productId String
  qtyUnits  Int             // SIGNED
  reason    StockMoveReason
  note      String?
  userId    String
  createdAt DateTime        @default(now())

  product Product @relation(fields: [productId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
}

// ========================================================================
// EXPENSES
// ========================================================================

model ExpenseCategory {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  expenses          Expense[]
  recurringExpenses RecurringExpense[]
}

model Expense {
  id               String               @id @default(cuid())
  date             DateTime             @default(now())
  amount           Int
  categoryId       String
  description      String
  paymentMethod    ExpensePaymentMethod
  paymentReference String?
  supplierId       String?
  recurringId      String?
  userId           String
  createdAt        DateTime             @default(now())

  category   ExpenseCategory   @relation(fields: [categoryId], references: [id])
  supplier   Supplier?         @relation(fields: [supplierId], references: [id])
  recurring  RecurringExpense? @relation(fields: [recurringId], references: [id])
  user       User              @relation(fields: [userId], references: [id])

  @@index([date])
  @@index([categoryId, date])
}

model RecurringExpense {
  id            String              @id @default(cuid())
  categoryId    String
  amount        Int
  description   String
  frequency     RecurringFrequency
  dayOfPeriod   Int                 // 1 = first of month, 0-6 for weekly
  active        Boolean             @default(true)
  lastRunAt     DateTime?
  createdAt     DateTime            @default(now())

  category ExpenseCategory @relation(fields: [categoryId], references: [id])
  expenses Expense[]
}

// ========================================================================
// SUBSCRIPTIONS
// ========================================================================

model Subscription {
  id                  String                @id @default(cuid())
  customerId          String
  productId           String
  frequency           SubscriptionFrequency
  qty                 Int
  saleUnit            SaleUnit
  dayOfWeek           Int?                  // 0-6 for weekly/biweekly
  unitPriceOverride   Int?
  startDate           DateTime
  endDate             DateTime?
  status              SubscriptionStatus    @default(ACTIVE)
  pausedUntil         DateTime?
  createdAt           DateTime              @default(now())

  customer Customer @relation(fields: [customerId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])

  @@index([status, dayOfWeek])
}

// ========================================================================
// LOYALTY
// ========================================================================

model LoyaltyMovement {
  id         String         @id @default(cuid())
  customerId String
  points     Int            // SIGNED
  reason     LoyaltyReason
  refType    String?
  refId      String?
  note       String?
  userId     String
  createdAt  DateTime       @default(now())

  customer Customer @relation(fields: [customerId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@index([customerId, createdAt])
}

model LoyaltyReward {
  id              String   @id @default(cuid())
  name            String
  description     String?
  pointsRequired  Int
  discountAmount  Int?
  discountPercent Int?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
}

// ========================================================================
// CUSTOMER PORTAL (Phase 4)
// ========================================================================

model CustomerUser {
  id              String    @id @default(cuid())
  customerId      String    @unique
  email           String?   @unique
  phone           String?   @unique
  passwordHash    String
  lastLoginAt     DateTime?
  emailVerifiedAt DateTime?
  phoneVerifiedAt DateTime?
  createdAt       DateTime  @default(now())

  customer Customer @relation(fields: [customerId], references: [id])
}

// ========================================================================
// RECEIPTS
// ========================================================================

model Receipt {
  id              String                @id @default(cuid())
  saleId          String
  format          ReceiptFormat
  destination     String?               // phone or email
  deliveredAt     DateTime?
  deliveryStatus  ReceiptDeliveryStatus @default(QUEUED)
  deliveryError   String?
  createdAt       DateTime              @default(now())

  sale Sale @relation(fields: [saleId], references: [id])
}

// ========================================================================
// AUDIT
// ========================================================================

model AuditLog {
  id         String      @id @default(cuid())
  tableName  String
  recordId   String
  action     AuditAction
  /// High-signal events get a category so the owner can filter them
  /// from the firehose of all mutations (LOGIN_SUCCESS, LOGIN_FAILED,
  /// CASH_LARGE_VARIANCE, etc). Plain CRUD writes leave it NULL.
  category   String?
  changes    Json
  userId     String?
  createdAt  DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([tableName, recordId])
  @@index([userId, createdAt])
  @@index([category, createdAt])
}

// ========================================================================
// SETTINGS (single-row org config)
// ========================================================================

/// Org-wide configuration: branding, theme, etc. Single row keyed by
/// the literal id "default" — enforce in code, not schema.
model Settings {
  id          String   @id @default("default")
  companyName String   @default("HydroMart Shop")
  theme       String   @default("default") // "default" | "sky" | "light-blue"
  logoPath    String?  // path relative to the uploads volume, e.g. "logo.png"
  /// Default minimum profit margin in basis points (10000 = 100%) for
  /// products that don't set their own Product.minMarginBps. 0 means
  /// "no global floor" — products without a min-margin will accept any
  /// discount that doesn't make the line total go negative.
  defaultMinMarginBps Int @default(0)
  updatedAt   DateTime @updatedAt
}

// ========================================================================
// IDEMPOTENCY (for write endpoints)
// ========================================================================

model IdempotencyKey {
  key        String   @id
  endpoint   String
  resultJson Json?
  createdAt  DateTime @default(now())
  expiresAt  DateTime

  @@index([expiresAt])
}
